---
import type { BodyServicesProps } from "./types";

const { servicesInfo, servicesImage } = Astro.props as BodyServicesProps;
---

<div class="body__services-element">
  <div class="body__services-element-image">
    <img src={servicesImage.img} alt={servicesImage.alt} />
  </div>

  <div class="body__services-element-info">
    <h3>{servicesInfo.title}</h3>
    <p>{servicesInfo.text}</p>
    <a href={servicesInfo.href}>
      <button class="BodyServices-btn">Подробнее</button>
    </a>
  </div>
</div>
