---
import type { FooterButtonsProps } from "./types";

const { title, items } = Astro.props as FooterButtonsProps;
---

<div class="footer__column">
  <div class="footer__title">
    <h3>{title}</h3>
  </div>

  <div class="footer__catalog-items">
    {
      items.map((item) => (
        <a href={item.href}>
          <button class="clients-btn">{item.button}</button>
        </a>
      ))
    }
  </div>
</div>
